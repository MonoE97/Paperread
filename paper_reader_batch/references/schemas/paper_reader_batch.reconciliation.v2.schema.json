{
  "$defs": {
    "ArtifactRef": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "minLength": 1,
          "title": "Artifact Id",
          "type": "string"
        },
        "path": {
          "minLength": 1,
          "title": "Path",
          "type": "string"
        },
        "schema_version": {
          "minLength": 1,
          "title": "Schema Version",
          "type": "string"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Sha256",
          "type": "string"
        },
        "size_bytes": {
          "minimum": 1,
          "title": "Size Bytes",
          "type": "integer"
        }
      },
      "required": [
        "path",
        "size_bytes",
        "sha256",
        "schema_version",
        "artifact_id"
      ],
      "title": "ArtifactRef",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "authorization_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Authorization Sha256",
      "type": "string"
    },
    "candidate_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Candidate Sha256",
      "type": "string"
    },
    "canonical_html_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Canonical Html Sha256",
      "type": "string"
    },
    "claim_id": {
      "title": "Claim Id",
      "type": "string"
    },
    "exact_title": {
      "minLength": 1,
      "title": "Exact Title",
      "type": "string"
    },
    "item_id": {
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,79}$",
      "title": "Item Id",
      "type": "string"
    },
    "lease_token_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Lease Token Sha256",
      "type": "string"
    },
    "manifest_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Manifest Sha256",
      "type": "string"
    },
    "match_count": {
      "minimum": 0,
      "title": "Match Count",
      "type": "integer"
    },
    "matched_note_key": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Matched Note Key"
    },
    "matched_note_keys": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "title": "Matched Note Keys",
      "type": "array"
    },
    "outcome": {
      "enum": [
        "verified",
        "not_found",
        "ambiguous",
        "blocked"
      ],
      "title": "Outcome",
      "type": "string"
    },
    "parent_key": {
      "minLength": 1,
      "title": "Parent Key",
      "type": "string"
    },
    "readback_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Readback Sha256",
      "type": "string"
    },
    "schema_version": {
      "const": "paper_reader_batch.reconciliation.v2",
      "title": "Schema Version",
      "type": "string"
    },
    "verification": {
      "anyOf": [
        {
          "$ref": "#/$defs/ArtifactRef"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "write_attempt_id": {
      "title": "Write Attempt Id",
      "type": "string"
    },
    "writer_id": {
      "minLength": 1,
      "title": "Writer Id",
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "manifest_sha256",
    "item_id",
    "writer_id",
    "claim_id",
    "lease_token_sha256",
    "write_attempt_id",
    "candidate_sha256",
    "authorization_sha256",
    "readback_sha256",
    "parent_key",
    "exact_title",
    "canonical_html_sha256",
    "matched_note_keys",
    "match_count",
    "outcome"
  ],
  "title": "ReconciliationResult",
  "type": "object"
}
