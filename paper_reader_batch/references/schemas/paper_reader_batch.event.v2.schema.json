    "FinishedData": {
      "additionalProperties": false,
      "properties": {
        "actor_id": {
          "minLength": 1,
          "title": "Actor Id",
          "type": "string"
        },
        "attempt_id": {
          "title": "Attempt Id",
          "type": "string"
        },
        "attempt_number": {
          "minimum": 1,
          "title": "Attempt Number",
          "type": "integer"
        },
        "candidate_sha256": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Candidate Sha256"
        },
        "claim_id": {
          "title": "Claim Id",
          "type": "string"
        },
        "failure_code": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Failure Code"
        },
        "failure_message": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Failure Message"
        },
        "item_id": {
          "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,79}$",
          "title": "Item Id",
          "type": "string"
        },
        "kind": {
          "enum": [
            "worker.finished",
            "local_prepare.finished"
          ],
          "title": "Kind",
          "type": "string"
        },
        "lease_token_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Lease Token Sha256",
          "type": "string"
        },
        "resolved_zotero_item_key": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Resolved Zotero Item Key"
        },
        "result_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Result Sha256",
          "type": "string"
        },
        "status": {
          "enum": [
            "succeeded",
            "failed",
            "blocked",
            "prepared"
          ],
          "title": "Status",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "item_id",
        "actor_id",
        "claim_id",
        "attempt_id",
        "attempt_number",
        "lease_token_sha256",
        "status",
        "result_sha256"
      ],
      "title": "FinishedData",
      "type": "object"
    },
